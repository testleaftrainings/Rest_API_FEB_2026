      "name": "create_a_new_record_in_incident_table_with_request_body_use_data_variable",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Status code name has Created\", function () {\r",
              "    pm.response.to.have.status(\"Created\");\r",
              "});\r",
              "\r",
              "pm.test(\"Validate response format should be JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.contains(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the short_description key value\", function () {\r",
              "    var jsonData = pm.response.json();    \r",
              "    pm.expect(jsonData.result.short_description).to.eql(pm.iterationData.get(\"ShortDescription\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the description key value\", function () {\r",
              "    var jsonData = pm.response.json();    \r",
              "    pm.expect(jsonData.result.description).to.eql(pm.iterationData.get(\"Description\"));\r",
              "});\r",
              "\r",
              "pm.test(\"Validate the category key value\", function () {\r",
              "    var jsonData = pm.response.json();    \r",
              "    pm.expect(jsonData.result.category).to.eql(pm.iterationData.get(\"Category\"));\r",
              "});"
            ],
